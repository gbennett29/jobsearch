# Copy to .env and fill from Firebase Console → Project settings → Your apps → SDK snippet.
# Then run: node scripts/generate-firebase-config.mjs
# Never commit .env or firebase-config.js.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
